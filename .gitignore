# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environment ────────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Logs (generated at runtime) ───────────────────────────────────────────────
logs/
*.log
wints_log_*.txt

# ── Scratch / debug files ──────────────────────────────────────────────────────
scratch/

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Video samples (generated by ffmpeg, not committed) ────────────────────────
video_server/samples/*.mp4
video_server/samples/*.ts

# ── MediaMTX binary (auto-downloaded by wints setup) ─────────────────────────
tools/mediamtx/mediamtx*
tools/mediamtx/*.tar.gz
tools/mediamtx/*.zip

# ── Mosquitto persistence ──────────────────────────────────────────────────────
*.db

# ── Test / coverage ───────────────────────────────────────────────────────────
htmlcov/
.coverage
coverage.xml

# ── Type checker / linter caches ─────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ── Scratch / debug scripts ───────────────────────────────────────────────────
scratch/

# ── Runtime log text files ────────────────────────────────────────────────────
wints_log_*.txt

# ── VSCode user settings (keep launch.json) ───────────────────────────────────
.vscode/settings.json
